#!/bin/sh

# Auto-cleanup worktrees whose remote branches were deleted (i.e. merged PRs)
# Runs after `git pull` on master.

# Only act when on master
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "master" ]; then
  exit 0
fi

# Prune stale remote-tracking refs
git fetch --prune --quiet

# Find worktrees whose branch no longer has a remote counterpart
git worktree list --porcelain | awk '
  /^worktree / { path = $2 }
  /^branch /   { branch = $2 }
  /^$/          { print path, branch }
' | while read -r wt_path wt_branch; do
  # Skip the main worktree (bare or current)
  if [ "$wt_path" = "$(git -C "$wt_path" rev-parse --show-toplevel 2>/dev/null)" ] && \
     [ "$(git rev-parse --show-toplevel)" = "$wt_path" ]; then
    continue
  fi

  # Skip if no branch recorded (detached HEAD)
  [ -z "$wt_branch" ] && continue

  # Strip refs/heads/ prefix
  short_branch="${wt_branch#refs/heads/}"

  # Check if remote tracking ref still exists
  if ! git show-ref --quiet "refs/remotes/origin/$short_branch"; then
    echo "→ Removing merged worktree: $wt_path ($short_branch)"
    git worktree remove --force "$wt_path" 2>/dev/null && \
      git branch -d "$short_branch" 2>/dev/null && \
      echo "  ✓ Done" || \
      echo "  ! Could not fully remove — check manually"
  fi
done
