#!/bin/sh

# Block direct commits to master
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "master" ]; then
  echo ""
  echo "ERROR: Direct commits to master are not allowed."
  echo ""
  echo "Create a worktree first:"
  echo "  git worktree add -b feature/<name> ../toolweb-<name>"
  echo "  cd ../toolweb-<name> && pnpm install"
  echo ""
  exit 1
fi
