/**
 * Site header — sticky 24-col grid nav.
 * z-40 so it sits above content but below StickyBar (z-50).
 */
---

<header class="sticky top-0 z-40 bg-white">
  <nav class="site-grid items-center py-[6.5px]">
    <a href="/" class="col-span-3 lg:col-span-2 text-body font-medium uppercase tracking-widest">Tool</a>
    <div class="hidden lg:block lg:col-span-20"></div>
    <a href="/book" class="col-span-3 lg:col-span-2 text-body text-right hover:text-caption-gray transition-colors">Book</a>
  </nav>
</header>
