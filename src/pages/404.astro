---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
---

<BaseLayout title="Not found — Tool">
  <Header />
  <main class="min-h-[100svh] flex items-center py-24 px-4" id="main-content">
    <div class="site-grid w-full">
      <div class="col-span-6 lg:col-span-24">
        <p class="text-hero font-bold tracking-tight">404</p>
        <p class="text-body text-caption-gray mt-2">Nothing here.</p>
        <a href="/" class="inline-block text-body border border-neutral-900 px-4 py-2 hover:bg-neutral-900 hover:text-white transition-colors mt-6">&larr; Back to Tool</a>
      </div>
    </div>
  </main>
  <Footer />
  <StickyBar />
</BaseLayout>
