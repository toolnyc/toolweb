interface Progress {
  phase?: string;
  currentPage?: number;
  totalPages?: number;
  currentCompany?: string;
  totalCompanies?: number;
  companiesSearched?: number;
  candidatesFound?: number;
  candidatesChecked?: number;
  enriched?: number;
  enrichFailed?: number;
  dupes?: number;
  lowScore?: number;
  added?: number;
  enrichLimit?: number;
  lastAdded?: string;
  error?: string;
}

function renderProgress(p: Progress) {
  const setText = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  setText('stat-found', String(p.candidatesFound ?? 0));
  const limit = p.enrichLimit ?? 10;
  setText('stat-enriched', `${p.enriched ?? 0}/${limit}`);
  setText('stat-added', String(p.added ?? 0));
  setText('stat-skipped', String((p.dupes ?? 0) + (p.lowScore ?? 0)));
  setText('stat-failed', String(p.enrichFailed ?? 0));

  const phase = document.getElementById('batch-phase');
  if (phase) {
    if (p.phase === 'searching') {
      if (p.currentCompany) {
        phase.textContent = `Searching ${p.currentCompany} (${p.companiesSearched ?? 0}/${p.totalCompanies ?? '?'})`;
      } else {
        phase.textContent = `Searching Apollo — page ${p.currentPage ?? 1} of ${p.totalPages ?? '?'}`;
      }
    } else if (p.phase === 'enriching') {
      const enriched = p.enriched ?? 0;
      phase.textContent = `Enriching candidates (${enriched}/${limit})`;
    } else if (p.phase === 'done') {
      phase.textContent = 'Complete';
    } else if (p.phase === 'stopped') {
      phase.textContent = 'Stopped — prospects saved';
    } else if (p.phase === 'error') {
      phase.textContent = 'Error';
    } else {
      phase.textContent = 'Starting...';
    }
  }

  const detail = document.getElementById('batch-detail');
  if (detail && p.lastAdded) {
    detail.classList.remove('hidden');
    detail.textContent = `Last added: ${p.lastAdded}`;
  }
}

window.startPolling = function startPolling(batchId: string) {
  _activeBatchId = batchId;
  const bar = document.getElementById('batch-status-bar');
  const cancelBtn = document.getElementById('cancel-batch-btn');
  const panel = document.getElementById('batch-progress-panel');
  const resultEl = document.getElementById('batch-result');
  const spinner = document.getElementById('batch-spinner');
  if (bar) bar.classList.remove('hidden');
  if (cancelBtn) cancelBtn.classList.remove('hidden');

  let failures = 0;
  let interval: number;
  interval = window.setInterval(async () => {
    try {
      const res = await fetch(`/api/outreach/batch-status?id=${batchId}`);
      if (!res.ok) {
        failures++;
        if (failures >= 5) {
          window.clearInterval(interval);
          if (resultEl) { resultEl.classList.remove('hidden'); resultEl.textContent = 'Status check failed — refresh the page.'; resultEl.className = 'px-5 py-3 border-t border-neutral-100 text-sm text-red-600'; }
        }
        return;
      }
      failures = 0;
      const data = await res.json() as { status: string; prospect_count: number; notes?: string; progress?: Progress };

      if (data.progress) renderProgress(data.progress);

      if (data.status === 'running') {
        // Stats update handled by renderProgress
      } else if (data.status === 'complete') {
        window.clearInterval(interval);
        if (cancelBtn) cancelBtn.classList.add('hidden');
        if (spinner) spinner.classList.add('hidden');
        if (panel) { panel.classList.remove('border-neutral-200'); panel.classList.add('border-green-200'); }
        const phaseEl = document.getElementById('batch-phase');
        if (phaseEl) { phaseEl.textContent = `Done — ${data.prospect_count ?? 0} prospects added`; phaseEl.classList.add('text-green-700'); }
        if (resultEl) { resultEl.classList.remove('hidden'); resultEl.textContent = 'Refreshing...'; resultEl.className = 'px-5 py-3 border-t border-neutral-100 text-sm text-green-600'; }
        setTimeout(() => window.location.reload(), 1500);
      } else if (data.status === 'failed') {
        window.clearInterval(interval);
        if (cancelBtn) cancelBtn.classList.add('hidden');
        if (spinner) spinner.classList.add('hidden');
        if (panel) { panel.classList.remove('border-neutral-200'); panel.classList.add('border-red-200'); }
        const phaseEl = document.getElementById('batch-phase');
        if (phaseEl) { phaseEl.textContent = 'Batch failed'; phaseEl.classList.add('text-red-600'); }
        if (resultEl) {
          resultEl.classList.remove('hidden');
          resultEl.className = 'px-5 py-3 border-t border-neutral-100 text-sm text-red-600';
          resultEl.textContent = data.notes ?? 'Unknown error';
        }
      }
    } catch {
      failures++;
      if (failures >= 5) {
        window.clearInterval(interval);
        if (resultEl) { resultEl.classList.remove('hidden'); resultEl.textContent = 'Status check failed — refresh the page.'; resultEl.className = 'px-5 py-3 border-t border-neutral-100 text-sm text-red-600'; }
      }
    }
  }, 1500) as unknown as number;
}

window.cancelBatch = async function cancelBatch() {
  if (!_activeBatchId) return;
  const res = await fetch('/api/outreach/cancel-batch', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ batch_id: _activeBatchId }),
  });
  if (res.ok) {
    window.location.reload();
  } else {
    const data = await res.json() as { error?: string };
    alert(data.error ?? 'Cancel failed');
  }
}
</script>
