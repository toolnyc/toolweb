---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
---

<BaseLayout title="Book a Call — Tool" description="Schedule a free 30-minute call to discuss your brand, design, or web development project.">
  <Header />
  <main class="py-16 px-4" id="main-content">
    <div class="site-grid py-8">
      <div class="col-span-6 md:col-span-8 mb-4">
        <p class="text-body font-medium">Book a call</p>
        <p class="text-body text-caption-gray mt-1">Pick a time that works for you.</p>
      </div>
    </div>
    <div class="site-grid">
      <div class="col-span-6 lg:col-span-24" id="cal-inline" style="min-height: 80vh;"></div>
    </div>
    <div class="site-grid py-8">
      <p class="col-span-6 md:col-span-8 text-body text-caption-gray">
        Prefer email? <a href="mailto:hugetool@proton.me" class="hover:text-neutral-900 transition-colors">hugetool@proton.me</a>
      </p>
    </div>
  </main>
  <Footer />
  <StickyBar />
</BaseLayout>

<script is:inline>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var config = { layout: "month_view" };
    if (params.get("name")) config.name = params.get("name");
    if (params.get("email")) config.email = params.get("email");
    if (params.get("notes")) config.notes = params.get("notes");

    Cal("inline", {
      calLink: document.querySelector('meta[name="cal-booking-url"]')?.content || "toolnyc/30min",
      elementOrSelector: "#cal-inline",
      config: config,
    });
  })();
</script>
