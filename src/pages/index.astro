---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
import Accordion from '../components/Accordion.astro';

import {
  getPublishedPortfolio,
  getPublishedWriting,
  getVisibleClientLogos,
  getSiteContentByKey,
} from '../lib/queries';

// Fetch all data in parallel
const [portfolio, writing, clients, heroTagline, aboutBlurb, servicesBlurb, processBlurb] = await Promise.all([
  getPublishedPortfolio(),
  getPublishedWriting(),
  getVisibleClientLogos(),
  getSiteContentByKey('hero_tagline'),
  getSiteContentByKey('about_blurb'),
  getSiteContentByKey('services_blurb'),
  getSiteContentByKey('process_blurb'),
]);

const quote = writing[0] ?? null;

// Build grid cells: portfolio items with quote and clients injected at fixed positions
type GridCell =
  | { type: 'portfolio'; item: typeof portfolio[number] }
  | { type: 'quote'; content: string; attribution: string | null }
  | { type: 'clients' };

const cells: GridCell[] = [];
let portfolioIndex = 0;

for (let i = 0; portfolioIndex < portfolio.length || i === 0; i++) {
  // Inject quote after 4 portfolio items
  if (portfolioIndex === 4 && quote) {
    cells.push({ type: 'quote', content: quote.content, attribution: quote.attribution });
  }
  // Inject clients after 8 portfolio items
  if (portfolioIndex === 8 && clients.length > 0) {
    cells.push({ type: 'clients' });
  }

  if (portfolioIndex < portfolio.length) {
    cells.push({ type: 'portfolio', item: portfolio[portfolioIndex] });
    portfolioIndex++;
  } else {
    break;
  }
}

// If we had fewer than 4 items, inject quote at end
if (portfolioIndex <= 4 && quote) {
  cells.push({ type: 'quote', content: quote.content, attribution: quote.attribution });
}
// If we had fewer than 8 items, inject clients at end
if (portfolioIndex <= 8 && clients.length > 0 && !cells.some(c => c.type === 'clients')) {
  cells.push({ type: 'clients' });
}
---

<BaseLayout>
  <Header />

  <main class="pb-12">
    {/* ── 1. Hero ─────────────────────────────────────────── */}
    <section class="min-h-[100svh] flex items-end site-grid pb-8">
      <div class="col-span-6 lg:col-span-24">
        <h1 class="text-hero font-bold uppercase tracking-tight">TOOL</h1>
        <p class="text-body text-caption-gray mt-2 max-w-md">
          {heroTagline?.content ?? 'Full-service creative technical consultancy'}
        </p>
      </div>
    </section>

    {/* ── 2. Content grid (masonry mosaic) ────────────────── */}
    <section class="content-grid">
      {cells.map((cell) => {
        if (cell.type === 'portfolio') {
          const item = cell.item;
          return (
            <div class="relative overflow-hidden">
              <div class="aspect-[4/3]">
                {item.media_type === 'video' ? (
                  <video
                    src={item.media_url}
                    poster={item.thumbnail_url ?? undefined}
                    autoplay
                    muted
                    loop
                    playsinline
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <img
                    src={item.media_url}
                    alt={item.title}
                    class="w-full h-full object-cover"
                  />
                )}
              </div>
              <div class="absolute inset-0 flex items-end">
                {item.external_url ? (
                  <a
                    href={item.external_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full p-3 bg-gradient-to-t from-black/50 to-transparent"
                  >
                    <span class="text-body text-white">{item.title}</span>
                  </a>
                ) : (
                  <div class="w-full p-3 bg-gradient-to-t from-black/50 to-transparent">
                    <span class="text-body text-white">{item.title}</span>
                  </div>
                )}
              </div>
            </div>
          );
        }

        if (cell.type === 'quote') {
          return (
            <div class="content-grid-span-2 flex items-center p-8 lg:p-12">
              <blockquote>
                <p class="text-body lg:text-lg italic leading-relaxed">
                  &ldquo;{cell.content}&rdquo;
                </p>
                {cell.attribution && (
                  <footer class="mt-4 text-body text-caption-gray">
                    &mdash; {cell.attribution}
                  </footer>
                )}
              </blockquote>
            </div>
          );
        }

        if (cell.type === 'clients') {
          return (
            <div class="content-grid-span-2 flex items-center p-8 lg:p-12">
              <div>
                <p class="text-body font-medium uppercase tracking-widest mb-4">Clients</p>
                <p class="text-body text-caption-gray leading-relaxed">
                  {clients.map((client, i) => (
                    <>
                      {i > 0 && <span> &middot; </span>}
                      {client.website_url ? (
                        <a
                          href={client.website_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-neutral-900 transition-colors"
                        >
                          {client.name}
                        </a>
                      ) : (
                        <span>{client.name}</span>
                      )}
                    </>
                  ))}
                </p>
              </div>
            </div>
          );
        }
      })}
    </section>

    {/* ── 3. Accordion sections ───────────────────────────── */}
    <section class="site-grid mt-[1px]">
      <div class="col-span-6 lg:col-span-24 space-y-[1px]">
        <Accordion title="Services">
          <p class="text-body text-caption-gray max-w-2xl">
            {servicesBlurb?.content ?? 'Branding, graphic design, web design & development, motion graphics, video production, technical consulting, and creative direction.'}
          </p>
        </Accordion>
        <Accordion title="Process">
          <p class="text-body text-caption-gray max-w-2xl">
            {processBlurb?.content ?? 'We start with a discovery conversation to understand your goals, then move through research, concepting, design, build, and launch. Every project is different — we tailor the process to fit.'}
          </p>
        </Accordion>
        <Accordion title="About">
          <p class="text-body text-caption-gray max-w-2xl">
            {aboutBlurb?.content ?? 'Tool is a creative technical consultancy based in New York. We work with brands, startups, and cultural institutions on branding, design, and software development.'}
          </p>
        </Accordion>
      </div>
    </section>

    {/* ── 4. Book CTA ─────────────────────────────────────── */}
    <section class="site-grid py-12">
      <div class="col-span-6 lg:col-span-24">
        <a
          href="/book"
          class="inline-block text-body font-medium uppercase tracking-widest hover:text-caption-gray transition-colors"
        >
          Book a call &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <StickyBar />
</BaseLayout>

<style>
  /* Text panels span 2 cols on tablet+, full width on mobile */
  .content-grid-span-2 {
    grid-column: span 1;
  }
  @media (min-width: 800px) {
    .content-grid-span-2 {
      grid-column: span 2;
    }
  }
</style>
